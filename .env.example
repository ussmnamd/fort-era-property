# ==========================================
# FRONTEND ENVIRONMENT VARIABLES
# ==========================================

# Sanity CMS Configuration (Free Tier)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-03-01
SANITY_API_TOKEN=your_sanity_api_token_here
SANITY_WEBHOOK_SECRET=your_webhook_secret_here

# Legacy Strapi Config (Deprecated - Remove after migration)
# NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# STRAPI_READ_TOKEN=your_read_only_api_token_here
# STRAPI_WRITE_TOKEN=your_write_api_token_here

# WhatsApp Business Number (Pakistan format: 923XXXXXXXXX)
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here

# ==========================================
# SANITY CMS SETUP INSTRUCTIONS
# ==========================================
# 1. Create free account at sanity.io
# 2. Create a new project
# 3. Install Sanity CLI: npm install -g @sanity/cli
# 4. Run: sanity init
# 5. Copy project ID to NEXT_PUBLIC_SANITY_PROJECT_ID
# 6. Generate API token at sanity.io/manage
# 7. Copy token to SANITY_API_TOKEN

# ==========================================
# LEAD SUBMISSION (Email/SMTP)
# ==========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password_here
AGENT_EMAIL=agent@yourdomain.com

# ==========================================
# OPTIONAL: CLOUDINARY (Media Storage)
# ==========================================

CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret
