# ==========================================
# SANITY STUDIO ENVIRONMENT VARIABLES
# ==========================================

# Your Sanity project ID (from sanity.io/manage)
SANITY_STUDIO_PROJECT_ID=your_project_id_here

# Dataset name (usually 'production' or 'development')
SANITY_STUDIO_DATASET=production

# API Token for studio access (optional for local development)
# SANITY_STUDIO_API_TOKEN=your_token_here
